@article{De_Moor_et_al_2018_spatial_behavior,
title = {{Are DNA data a valid source to study the spatial behavior of unknown offenders?}},
journal = {Science \& Justice},
volume = {58},
number = {5},
pages = {315-322},
year = {2018},
issn = {1355-0306},
doi = {https://doi.org/10.1016/j.scijus.2018.04.003},
url = {https://www.sciencedirect.com/science/article/pii/S1355030618300236},
author = {Sabine {De Moor} and Christophe Vandeviver and Tom {Vander Beken}},
keywords = {Offending behaviour, DNA data, Police recorded crime data, Spatial point pattern test},
abstract = {Studying the spatial behaviour of unknown offenders (i.e. undetected offenders) is difficult, because police recorded crime data do not contain information about these offenders. Recently, forensic DNA data has been used to study unknown offenders. However, DNA data are only a subset of the crimes committed by unknown offenders stored in police recorded crime data. To establish the suitability of DNA data for studying the spatial offending behaviour of unknown offenders, we examine the concentration and spatial similarity of detected but unsolved crimes in police recorded crime data (N = 181,483) and DNA data (N = 1913) over 27 Belgian judicial districts for four crime types. We established spatial similarity for certain crime types (in some districts). This offers opportunities for DNA data to be used to study unknown offenders' spatial offending behaviour. Implications for theory and research are discussed.}
}

