@incollection{Jeuniaux_et_al_2018_trajectories,
    keywords        = {CV, CV_chapter},
    title = {Reconstruction and study of offending trajectories through forensic evidence – an illustration using a forensic {DNA} database},
    abstract = {Offending trajectories or criminal careers – the sequences of crimes that a same individual has committed – is an important concept of criminology research as it helps answering research questions from a longitudinal perspective. But reconstructing the true offending trajectories is a challenge as we may suffer from issues pertaining to (a) unit selection, (b) unit counting, (c) unit ordering and (d) unit characterization. Three types of data sources can be used to accomplish the reconstruction process: (1) official records, (2) surveys and (3) operational devices such as forensic databases. Each type presents advantages and disadvantages, and none is perfect. Despite their particular drawbacks, one of the advantages of forensic databases is that they can answer questions on criminal careers of unknown and known individuals alike. We illustrate our points through a case study of 7535 offenders recorded in the Belgian national forensic {DNA} database.},
    booktitle = {International Handbook of Forensic Criminology},
    author = {Jeuniaux, Patrick P.J.M.H. and De Moor, Sabine and Robert, Luc and Renard, Bertrand and Stappers, Caroline and Vanvooren, Vanessa},
    year = 2018,
    isbn = {9781138688216},
    doi = {10.4324/9781315541945-15},
    publisher = {Routledge},
    address = {London},
    pages = {177-190},
    editor = {Rossy, Quentin and Décary-Hétu, David and Delémont, Olivier and Mulone, Massimiliano}
}

