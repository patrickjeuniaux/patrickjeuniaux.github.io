@article{Jonckheere_et_al_2021_travail_terrorisme_criminologie,
    keywords        = {CV, CV_article},
    author = {Jonckheere, Alexia and Mine, Benjamin and Detry, Isabelle and Jeuniaux, Patrick},
    title = {Travail social en justice et terrorisme. La gestion de l'information par les agents de probation.},
    volume = {54},
    number = {2},
    year = {2021},
    url = {https://www.erudit.org/fr/revues/crimino/2021-v54-n2-crimino06596/1084299ar/},
    doi = {10.7202/1084299ar},
    pages = {321-345},
    journaltitle = {Criminologie},
    abstract = {Les agents de probation sont amenés à accompagner des personnes suspectées ou condamnées dans le cadre de dossiers de terrorisme. Une enquête menée au sein des services de probation belges francophones (maisons de justice) montre combien ces dossiers font évoluer l’activité des travailleurs, confrontés à l’intensification et à la multiplication de nouvelles relations de travail, notamment avec les services de sécurité et de renseignement. La gestion de l’information est désormais au cœur de cette activité, ce qui est inédit au regard des spécificités du travail social en justice, toujours à la recherche d’un point d’équilibre entre aide et contrôle. / Probation officers are required to support suspected or convicted persons in terrorism cases. A survey carried out within the French-speaking Belgian probation services (houses of justice) shows how these cases are changing the activity of probation officer’s, who are confronted with the intensification and multiplication of new working relationships, particularly with the security and intelligence services. Information management now occupies a central place in the activity of the social workers, which is unprecedented in view of the specificities of social work in justice, always looking for a balance between assistance and control.}
}

