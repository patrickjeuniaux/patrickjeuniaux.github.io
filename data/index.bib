@inproceedings{Chowdhury_et_al_2024_cross_examine,
  author       = {Chowdhury, Saurav and Joshi, Suyog and Dey, Lipika},
  title        = {{Cross Examine: An Ensemble-Based Approach to Leverage Large Language Models for Legal Text Analytics}},
  booktitle    = {Proceedings of the Natural Legal Language Processing Workshop 2024},
  editor       = {Aletras, Nikolaos and Chalkidis, Ilias and Barrett, Leslie and Goanțǎ, Cǎtǎlina and Preoțiuc-Pietro, Daniel and Spanakis, Gerasimos},
  publisher    = {Association for Computational Linguistics},
  address      = {Miami, FL, USA},
  year         = {2024},
  month        = nov,
  pages        = {194--204},
  doi          = {10.18653/v1/2024.nllp-1.16},
  url          = {https://aclanthology.org/2024.nllp-1.16/},
  abstract     = {Legal documents are complex in nature, describing a course of argumentative reasoning followed to settle a case. Processing large volumes of such documents is essential for legal professionals. NLP methods that aid in summarization, insight extraction, and question answering are crucial in legal analytics. Traditional supervised models require costly annotated data. This paper proposes a legal text analytics pipeline using Large Language Models that function with minimal training data. Document summarization uses an iterative retrieval-augmented generation approach, and a novel ontology-driven ensemble is proposed for question answering, emulating cross-examination. A knowledge graph captures key entities and relationships. A new dataset of Indian bail applications under the POCSO Act (2012) is introduced. Analysis of extracted insights reveals crime patterns and social contexts, offering value to both legal professionals and social scientists.}
}

