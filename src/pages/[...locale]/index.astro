---
import HomePage from '../../components/pages/HomePage.astro';
import { locales, type Locale, normalizeLocale } from '../../i18n/ui';
export function getStaticPaths() {
  return [
    ...locales.map((locale) => ({ params: { locale } })),
    { params: { locale: undefined } }
  ];
}
const locale = normalizeLocale(Astro.params.locale) as Locale;
---
<HomePage locale={locale} />
