---
import { getCollection } from 'astro:content';
import { locales } from '../../../i18n/ui';
import { getLocalizedBlogGroups } from '../../../lib/blog';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const filtered = posts.filter((post) => !post.data.draft);
  const extendedLocales = [...locales, undefined];
  return extendedLocales.flatMap((locale) => getLocalizedBlogGroups(filtered, locale).map((post) => ({
    params: { locale, slug: post.slug },
  })));
}

const locale = Astro.params.locale;
const slugParam = Astro.params.slug;
const slug = Array.isArray(slugParam) ? slugParam.join('/') : slugParam || '';
const redirectPath = locale ? `/${locale}/notes/${slug}/` : `/notes/${slug}/`;
return Astro.redirect(redirectPath);
---
