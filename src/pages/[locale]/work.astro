---
import PublicationsPage from '../../components/pages/PublicationsPage.astro';
import { locales, type Locale, normalizeLocale } from '../../i18n/ui';
export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}
const locale = normalizeLocale(Astro.params.locale) as Locale;
---
<PublicationsPage locale={locale} />
